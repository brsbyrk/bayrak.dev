---
import { formatDate } from '@/utils/data.util';
import Tags from './Tags.astro';
interface Props {
	project: any;
}

const { project } = Astro.props;
---

<a href={project.url}>
	<div
		class="h-full rounded-2xl bg-stone-200/50 from-blue-50 via-blue-600 to-white p-[1px] text-sm shadow-[inset_0_0_0_1px_rgba(255,255,255,0.4)] hover:bg-gradient-to-tr dark:bg-gray-900"
	>
		<div
			class="flex h-full w-full flex-col rounded-[1rem] bg-stone-300 p-4 text-gray-900 opacity-90 dark:bg-stone-800 dark:text-white"
		>
			<div class="flex-auto">
				<div class="flex justify-between pb-4 text-xs">
					<p>{formatDate(project.frontmatter.pubDate)}</p>
					<!-- <p>{post.frontmatter.minutesRead}</p> -->
				</div>

				<p class="pb-4 text-lg font-bold">{project.frontmatter.title}</p>

				<Tags tags={project.frontmatter.tags} />
				<p class="line-clamp-6 pt-4">{project.frontmatter.excerpt}</p>
			</div>
			<p class="pt-4 underline">read more →</p>
		</div>
	</div>
</a>
